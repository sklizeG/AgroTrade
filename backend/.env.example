PORT=3000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/agrotrade?schema=public"
JWT_SECRET="change-me-for-local-dev"
# Comma-separated if needed, e.g. http://localhost:5173,http://127.0.0.1:5173
CORS_ORIGIN="http://localhost:5173,http://127.0.0.1:5173"
ADMIN_EMAIL="admin@agrotrade.local"
ADMIN_PASSWORD="Admin123!"
CRM_ENABLED=true
# На Windows для Node fetch надёжнее 127.0.0.1, чем localhost (IPv6)
CRM_BASE_URL="http://127.0.0.1:8085"
CRM_USERNAME="admin"
CRM_PASSWORD="admin123"
# Валюта суммы сделки (opportunityAmount) в EspoCRM, например RUB
CRM_LEAD_CURRENCY=RUB
