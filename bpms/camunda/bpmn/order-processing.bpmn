<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpm" id="Definitions_AgroTrade" targetNamespace="http://agrotrade.local/bpmn" exporter="Camunda Modeler" exporterVersion="5.0.0">
  <bpmn:process id="OrderProcessing" name="Обработка заказа AgroTrade" isExecutable="true" camunda:historyTimeToLive="P180D">
    <bpmn:startEvent id="StartEvent_OrderCreated" name="Лид создан в CRM">
      <bpmn:outgoing>Flow_start_review</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="Task_ManagerReview" name="Проверить заявку" camunda:candidateGroups="manager">
      <bpmn:documentation>Менеджер проверяет данные заказа, контакт покупателя и кампанию.</bpmn:documentation>
      <bpmn:incoming>Flow_start_review</bpmn:incoming>
      <bpmn:outgoing>Flow_review_gateway</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_Payment" name="Оплачен?">
      <bpmn:incoming>Flow_review_gateway</bpmn:incoming>
      <bpmn:incoming>Flow_payment_retry</bpmn:incoming>
      <bpmn:outgoing>Flow_to_confirm</bpmn:outgoing>
      <bpmn:outgoing>Flow_to_payment_followup</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="Task_ManagerPaymentFollowup" name="Контроль оплаты" camunda:candidateGroups="manager">
      <bpmn:documentation>Напомнить покупателю об оплате, если статус pending_payment.</bpmn:documentation>
      <bpmn:incoming>Flow_to_payment_followup</bpmn:incoming>
      <bpmn:outgoing>Flow_payment_retry</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_AdminConfirm" name="Подтвердить резерв" camunda:candidateGroups="admin">
      <bpmn:documentation>Администратор подтверждает резерв объёма по кампании.</bpmn:documentation>
      <bpmn:incoming>Flow_to_confirm</bpmn:incoming>
      <bpmn:outgoing>Flow_admin_farmer</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_FarmerPrepare" name="Подготовить продукцию" camunda:candidateGroups="farmer">
      <bpmn:documentation>Фермер готовит объём к отгрузке или самовывозу.</bpmn:documentation>
      <bpmn:incoming>Flow_admin_farmer</bpmn:incoming>
      <bpmn:outgoing>Flow_farmer_ship</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_ManagerShipment" name="Организовать отгрузку" camunda:candidateGroups="manager">
      <bpmn:documentation>Менеджер координирует логистику и частичную поставку.</bpmn:documentation>
      <bpmn:incoming>Flow_farmer_ship</bpmn:incoming>
      <bpmn:outgoing>Flow_ship_delivery</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_ManagerDelivery" name="Подтвердить доставку" camunda:candidateGroups="manager">
      <bpmn:documentation>Фиксация факта доставки или самовывоза.</bpmn:documentation>
      <bpmn:incoming>Flow_ship_delivery</bpmn:incoming>
      <bpmn:outgoing>Flow_delivery_close</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_AdminClose" name="Закрыть заказ" camunda:candidateGroups="admin">
      <bpmn:documentation>Администратор завершает процесс и архивирует карточку.</bpmn:documentation>
      <bpmn:incoming>Flow_delivery_close</bpmn:incoming>
      <bpmn:outgoing>Flow_close_end</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="EndEvent_Completed" name="Заказ завершён">
      <bpmn:incoming>Flow_close_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_start_review" sourceRef="StartEvent_OrderCreated" targetRef="Task_ManagerReview" />
    <bpmn:sequenceFlow id="Flow_review_gateway" sourceRef="Task_ManagerReview" targetRef="Gateway_Payment" />
    <bpmn:sequenceFlow id="Flow_to_confirm" name="Оплачен / reserved+" sourceRef="Gateway_Payment" targetRef="Task_AdminConfirm">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">${status != 'pending_payment' &amp;&amp; status != 'cancelled'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_to_payment_followup" name="Ожидает оплату" sourceRef="Gateway_Payment" targetRef="Task_ManagerPaymentFollowup">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">${status == 'pending_payment'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_payment_retry" sourceRef="Task_ManagerPaymentFollowup" targetRef="Gateway_Payment" />
    <bpmn:sequenceFlow id="Flow_admin_farmer" sourceRef="Task_AdminConfirm" targetRef="Task_FarmerPrepare" />
    <bpmn:sequenceFlow id="Flow_farmer_ship" sourceRef="Task_FarmerPrepare" targetRef="Task_ManagerShipment" />
    <bpmn:sequenceFlow id="Flow_ship_delivery" sourceRef="Task_ManagerShipment" targetRef="Task_ManagerDelivery" />
    <bpmn:sequenceFlow id="Flow_delivery_close" sourceRef="Task_ManagerDelivery" targetRef="Task_AdminClose" />
    <bpmn:sequenceFlow id="Flow_close_end" sourceRef="Task_AdminClose" targetRef="EndEvent_Completed" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="OrderProcessing">
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_OrderCreated">
        <dc:Bounds x="152" y="212" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ManagerReview_di" bpmnElement="Task_ManagerReview">
        <dc:Bounds x="240" y="190" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Payment_di" bpmnElement="Gateway_Payment" isMarkerVisible="true">
        <dc:Bounds x="395" y="205" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ManagerPaymentFollowup_di" bpmnElement="Task_ManagerPaymentFollowup">
        <dc:Bounds x="370" y="320" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AdminConfirm_di" bpmnElement="Task_AdminConfirm">
        <dc:Bounds x="500" y="190" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_FarmerPrepare_di" bpmnElement="Task_FarmerPrepare">
        <dc:Bounds x="650" y="190" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ManagerShipment_di" bpmnElement="Task_ManagerShipment">
        <dc:Bounds x="800" y="190" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ManagerDelivery_di" bpmnElement="Task_ManagerDelivery">
        <dc:Bounds x="950" y="190" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AdminClose_di" bpmnElement="Task_AdminClose">
        <dc:Bounds x="1100" y="190" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_1_di" bpmnElement="EndEvent_Completed">
        <dc:Bounds x="1252" y="212" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_start_review_di" bpmnElement="Flow_start_review">
        <di:waypoint x="188" y="230" />
        <di:waypoint x="240" y="230" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_review_gateway_di" bpmnElement="Flow_review_gateway">
        <di:waypoint x="340" y="230" />
        <di:waypoint x="395" y="230" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_to_confirm_di" bpmnElement="Flow_to_confirm">
        <di:waypoint x="445" y="230" />
        <di:waypoint x="500" y="230" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_to_payment_followup_di" bpmnElement="Flow_to_payment_followup">
        <di:waypoint x="420" y="255" />
        <di:waypoint x="420" y="320" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_payment_retry_di" bpmnElement="Flow_payment_retry">
        <di:waypoint x="370" y="360" />
        <di:waypoint x="340" y="360" />
        <di:waypoint x="340" y="255" />
        <di:waypoint x="395" y="255" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_admin_farmer_di" bpmnElement="Flow_admin_farmer">
        <di:waypoint x="600" y="230" />
        <di:waypoint x="650" y="230" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_farmer_ship_di" bpmnElement="Flow_farmer_ship">
        <di:waypoint x="750" y="230" />
        <di:waypoint x="800" y="230" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ship_delivery_di" bpmnElement="Flow_ship_delivery">
        <di:waypoint x="900" y="230" />
        <di:waypoint x="950" y="230" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_delivery_close_di" bpmnElement="Flow_delivery_close">
        <di:waypoint x="1050" y="230" />
        <di:waypoint x="1100" y="230" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_close_end_di" bpmnElement="Flow_close_end">
        <di:waypoint x="1200" y="230" />
        <di:waypoint x="1252" y="230" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
